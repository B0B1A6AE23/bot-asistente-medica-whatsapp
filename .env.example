# ============================================================
# Clínica Ejemplo Medical Care — Bot WhatsApp Config
# Copia este archivo a .env y rellena los valores reales
# ============================================================

# --- Groq (IA gratis, 14,400 req/día) ---
# Obtén tu key en: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Doctor / Admin ---
# Número del médico principal (con código de país, sin +)
DOCTOR_PHONE=52XXXXXXXXXX

# Nombre del médico principal (usado en prompt del LLM y mensajes)
DOCTOR_NAME=Dr. Ejemplo

# Nombre de la clínica (aparece en mensajes del bot)
CLINIC_NAME=Clínica Ejemplo Medical Care

# Horarios de atención (aparece en respuestas del bot)
CLINIC_HOURS=Lunes a Viernes, 8:00 AM a 8:00 PM

# --- Contactos personales a ignorar ---
# Lista de teléfonos (sin +, separados por coma) que NO deben ser procesados por el bot.
# Útil cuando el número de WhatsApp del bot es un número personal:
# los chats privados del dueño no activarán respuestas automáticas.
# Ejemplo: IGNORED_PHONES=5219611234567,5215512345678
IGNORED_PHONES=

# --- Seguridad del servidor HTTP ---
# Token para el endpoint /send-message (invéntalo largo y aleatorio)
API_SECRET_TOKEN=cambia-esto-por-un-token-secreto-largo

# --- Google Calendar (opcional, puede dejarse vacío) ---
# Path al archivo JSON de Service Account descargado de Google Cloud
GOOGLE_CREDENTIALS_PATH=./auth/google-credentials.json

# ID del calendario donde se crearán los eventos
# (correo del calendar, ej: tucalendario@gmail.com)
GOOGLE_CALENDAR_ID=

# --- Puerto del servidor HTTP ---
PORT=3000

# --- Entorno ---
NODE_ENV=production
